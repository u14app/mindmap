{
  "name": "@xiangfa/mindmap",
  "description": "A beautiful, interactive mind map component for React.",
  "license": "Apache-2.0",
  "private": false,
  "version": "0.6.5",
  "type": "module",
  "main": "dist/mindmap.umd.cjs",
  "module": "dist/esm/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": [
    "*.css",
    "./dist/esm/plugins/latex.js"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/mindmap.umd.cjs"
      }
    },
    "./viewer": {
      "import": {
        "types": "./dist/viewer.d.ts",
        "default": "./dist/esm/MindMapViewer.js"
      }
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:lib": "rm -rf dist && vite build --mode lib && tsc -p tsconfig.lib.json",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "katex": ">=0.16"
  },
  "peerDependenciesMeta": {
    "katex": {
      "optional": true
    }
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.0"
  }
}
